---
// Inline SVG logo placeholder — a simple "moulding" mark for Pupa.
interface Props {
  size?: number;
}
const { size = 26 } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Pupa logo"
>
  <defs>
    <linearGradient id="pupaGrad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
      <stop stop-color="#7c9cff" />
      <stop offset="1" stop-color="#b48cff" />
    </linearGradient>
  </defs>
  <rect x="2" y="2" width="28" height="28" rx="8" fill="url(#pupaGrad)" />
  <rect x="8" y="8" width="7" height="7" rx="2" fill="#0d0f13" opacity="0.85" />
  <rect x="17" y="8" width="7" height="7" rx="2" fill="#0d0f13" opacity="0.55" />
  <rect x="8" y="17" width="7" height="7" rx="2" fill="#0d0f13" opacity="0.55" />
  <rect x="17" y="17" width="7" height="7" rx="3.5" fill="#0d0f13" opacity="0.85" />
</svg>
