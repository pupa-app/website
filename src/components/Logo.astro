---
// The Pupa brand mark — the real app icon (a segmented pupa/larva) from
// ../pupa (Pupa/Sources/PupaApp/Resources/AppIcon.png). Transparent red on
// whatever sits behind it, so it reads cleanly on the dark header.
import { href } from '../lib/href';
interface Props {
  size?: number;
}
const { size = 26 } = Astro.props;
---
<img
  src={href('/pupa-mark.png')}
  width={size}
  height={size}
  alt="Pupa logo"
  class="pupa-mark"
  decoding="async"
/>
