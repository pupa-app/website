---
import Logo from './Logo.astro';
import { href } from '../lib/href';

const GITHUB_ORG = 'https://github.com/pupa-app';
const MARKETPLACE = 'https://github.com/pupa-app/marketplace';
---
<header class="site-header">
  <div class="container bar">
    <a href={href('/')} class="brand" aria-label="Pupa — home">
      <Logo size={36} />
    </a>
    <details class="nav-menu">
      <summary class="nav-menu__btn" aria-label="Toggle navigation menu">
        <span class="nav-menu__icon" aria-hidden="true"></span>
      </summary>
      <nav class="nav" aria-label="Primary">
        <a href={href('/tutorials')}>Tutorials</a>
        <a href={href('/blog')}>Blog</a>
        <a href={MARKETPLACE}>Marketplace</a>
        <a href={GITHUB_ORG}>GitHub</a>
        <a href={href('/support')}>Support</a>
      </nav>
    </details>
  </div>
</header>
