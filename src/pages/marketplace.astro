---
import BaseLayout from '../layouts/BaseLayout.astro';

// The marketplace is "just a URL": an index.json manifest that points at .pupa
// bundle files. We fetch it CLIENT-SIDE from the repo's main branch so the page
// reflects the live catalog on every visit — no website rebuild needed when the
// marketplace changes. Cards are built in the <script> below; a fetch failure
// degrades to an inline "unavailable" state.
const MARKETPLACE_REPO = 'https://github.com/pupa-app/marketplace';
const BASE = 'https://raw.githubusercontent.com/pupa-app/marketplace/main/';
---
<BaseLayout
  title="Marketplace"
  description="Browse the official Pupa marketplace — ready-made MyApp bundles you can open straight in Pupa. Each app is inert, portable .pupa data; review its agent prompts on import."
>
  <section class="section container mkt" data-base={BASE} data-repo={MARKETPLACE_REPO}>
    <h1 class="mkt__title">Pupa Marketplace</h1>
    <p class="mkt__lead">Ready-made MyApp bundles you can open straight in Pupa.</p>

    <!-- How opening works (honest about the current file-open flow). -->
    <details class="mkt__how">
      <summary>How “Open in Pupa” works</summary>
      <div class="mkt__how-body">
        <p>
          A <code>.pupa</code> bundle is inert, portable data — no code runs on
          import. Tapping <strong>Open in Pupa</strong> downloads the bundle;
          your device then offers to open it in Pupa, which shows a confirm
          preview so you can <strong>review the app’s agent prompts before
          installing</strong>.
        </p>
        <ul class="mkt__how-steps">
          <li><strong>iOS:</strong> tap → “Open in Pupa” from the download.</li>
          <li><strong>macOS:</strong> the file downloads — open it to launch Pupa.</li>
        </ul>
        <p class="mkt__how-note">
          Want to publish your own app? See the{' '}
          <a href={MARKETPLACE_REPO}>marketplace repo</a>.
        </p>
      </div>
    </details>

    <!-- Populated by the client fetch. Loading → grid, or → error. -->
    <div data-mkt-status>
      <p class="mkt__loading" role="status">Loading apps…</p>
    </div>

    <p class="mkt__foot">
      Live from the <a href={MARKETPLACE_REPO}>marketplace repo</a>.
      Want your app here? <a href={`${MARKETPLACE_REPO}#publish-your-app`}>Publish it →</a>
    </p>
  </section>

  <script>
    interface Entry {
      id: string; name: string; author: string; summary: string;
      tags: string[]; appVersion: string; path: string; sizeBytes: number;
      homepage?: string; includedMemories: boolean; includedRecords: boolean;
    }
    interface Index { entries: Entry[] }

    const root = document.querySelector<HTMLElement>('.mkt');
    const status = root?.querySelector<HTMLElement>('[data-mkt-status]');
    if (root && status) {
      const BASE = root.dataset.base!;
      const REPO = root.dataset.repo!;
      const kb = (b: number) => `${Math.max(1, Math.round(b / 1024))} KB`;
      const monogram = (n: string) => n.trim()[0]?.toUpperCase() ?? '?';
      const DOWNLOAD_ICON =
        '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>';

      // Build a card with DOM APIs — all catalog text goes through textContent,
      // so nothing from the manifest is ever interpreted as HTML.
      const card = (e: Entry): HTMLElement => {
        const li = document.createElement('li');
        li.className = 'app-card';

        const head = el('div', 'app-card__head');
        head.append(el('span', 'app-card__icon', monogram(e.name), { 'aria-hidden': 'true' }));
        const id = el('div', 'app-card__id');
        id.append(el('h2', 'app-card__name', e.name), el('p', 'app-card__by', `by ${e.author}`));
        head.append(id);
        li.append(head);

        li.append(el('p', 'app-card__summary', e.summary));

        if (e.tags?.length) {
          const tags = el('ul', 'app-card__tags');
          tags.setAttribute('aria-label', 'Tags');
          e.tags.forEach((t) => tags.append(el('li', 'app-card__tag', t)));
          li.append(tags);
        }

        const meta = el('dl', 'app-card__meta');
        meta.append(metaPair('Size', kb(e.sizeBytes)));
        meta.append(metaPair('Exported by', `Pupa ${e.appVersion}`));
        if (e.includedRecords) meta.append(metaPair('Includes', 'sample data'));
        if (e.includedMemories) meta.append(metaPair('Includes', 'memories'));
        li.append(meta);

        const actions = el('div', 'app-card__actions');
        const open = document.createElement('a');
        open.className = 'btn btn-primary';
        open.href = BASE + e.path; // real link: middle-click / no-JS fallback
        open.setAttribute('download', `${e.id}.pupa`);
        open.innerHTML = DOWNLOAD_ICON;
        open.append(' Open in Pupa');
        // The bundle lives on another origin (raw.githubusercontent), where the
        // `download` attribute is ignored and the .pupa is served as text/plain
        // — so a plain link just renders the JSON. Fetch the bytes and download
        // via a same-origin Blob URL, which forces a real ".pupa" file the OS
        // can hand to Pupa.
        open.addEventListener('click', async (ev) => {
          ev.preventDefault();
          if (open.classList.contains('is-busy')) return;
          open.classList.add('is-busy');
          try {
            const res = await fetch(BASE + e.path, { cache: 'no-cache' });
            if (!res.ok) throw new Error(String(res.status));
            const blob = new Blob([await res.arrayBuffer()], { type: 'application/octet-stream' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `${e.id}.pupa`;
            document.body.append(a);
            a.click();
            a.remove();
            setTimeout(() => URL.revokeObjectURL(url), 4000);
          } catch (err) {
            console.warn(`[marketplace] download failed for ${e.id}: ${err}`);
            window.location.href = BASE + e.path; // last resort
          } finally {
            open.classList.remove('is-busy');
          }
        });
        actions.append(open);
        if (e.homepage && /^https:\/\//.test(e.homepage)) {
          const details = document.createElement('a');
          details.className = 'btn';
          details.href = e.homepage;
          details.textContent = 'Details';
          actions.append(details);
        }
        li.append(actions);
        return li;
      };

      const showError = () => {
        status.innerHTML = '';
        const box = el('div', 'mkt__error');
        box.setAttribute('role', 'alert');
        box.append(el('h2', 'mkt__error-title', 'Catalog unavailable'));
        const p = el('p', '', 'The marketplace catalog couldn’t be reached right now. Try again later, or view the source on the ');
        const a = document.createElement('a');
        a.href = REPO; a.textContent = 'marketplace repo';
        p.append(a, '.');
        box.append(p);
        status.append(box);
      };

      fetch(BASE + 'index.json', { cache: 'no-cache' })
        .then((r) => { if (!r.ok) throw new Error(`${r.status}`); return r.json() as Promise<Index>; })
        .then((data) => {
          const ul = document.createElement('ul');
          ul.className = 'mkt__grid';
          ul.setAttribute('role', 'list');
          (data.entries ?? []).forEach((e) => ul.append(card(e)));
          status.replaceChildren(ul);
        })
        .catch((err) => { console.warn(`[marketplace] ${err}`); showError(); });

      function el(tag: string, cls: string, text?: string, attrs?: Record<string, string>) {
        const node = document.createElement(tag);
        if (cls) node.className = cls;
        if (text != null) node.textContent = text;
        if (attrs) for (const [k, v] of Object.entries(attrs)) node.setAttribute(k, v);
        return node;
      }
      function metaPair(term: string, val: string) {
        const div = document.createElement('div');
        div.append(el('dt', '', term), el('dd', '', val));
        return div;
      }
    }
  </script>
</BaseLayout>
