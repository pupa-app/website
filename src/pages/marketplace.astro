---
import BaseLayout from '../layouts/BaseLayout.astro';
import { href } from '../lib/href';

// The marketplace is "just a URL": an index.json manifest that points at .pupa
// bundle files. We read it at BUILD time from a pinned release tag (clients pin
// tags too — see the marketplace repo README), so this page tracks exactly what
// was published, with zero client-side JS. Bump the tag on a marketplace
// release. A fetch failure fails the build on purpose — better than shipping an
// empty catalog on a transient blip.
const MARKETPLACE_REPO = 'https://github.com/pupa-app/marketplace';
const MARKETPLACE_TAG = 'v0.0.2';
const BASE = `https://raw.githubusercontent.com/pupa-app/marketplace/${MARKETPLACE_TAG}/`;

interface Entry {
  id: string;
  name: string;
  icon: string;
  author: string;
  summary: string;
  tags: string[];
  version: number;
  appVersion: string;
  path: string;
  sizeBytes: number;
  homepage?: string;
  includedMemories: boolean;
  includedRecords: boolean;
}
interface Index {
  name: string;
  owner: string;
  description: string;
  entries: Entry[];
}

// Read the published catalog at the pinned tag at build time. A failure does
// NOT crash the build — we render a clean "unavailable" state on the page so a
// transient outage (or the repo not yet being public) degrades gracefully
// instead of shipping a 500.
let index: Index | null = null;
let loadError: string | null = null;
try {
  const res = await fetch(BASE + 'index.json');
  if (!res.ok) throw new Error(`index.json returned ${res.status}`);
  index = await res.json();
} catch (err) {
  loadError = (err as Error).message;
  console.warn(`[marketplace] catalog unavailable at ${BASE}: ${loadError}`);
}

const kb = (bytes: number) => `${Math.max(1, Math.round(bytes / 1024))} KB`;
// Bundle URL resolved against the pinned base — this is what a button links to.
const bundleURL = (e: Entry) => BASE + e.path;
// Monogram stands in for the bundle's SF Symbol icon (not renderable on web).
const monogram = (name: string) => name.trim()[0]?.toUpperCase() ?? '?';
---
<BaseLayout
  title="Marketplace"
  description="Browse the official Pupa marketplace — ready-made MyApp bundles you can open straight in Pupa. Each app is inert, portable .pupa data; review its agent prompts on import."
>
  <section class="section container mkt">
    <p class="section-eyebrow">Marketplace</p>
    <h1 class="mkt__title">{index?.name ?? 'Pupa Marketplace'}</h1>
    <p class="mkt__lead">{index?.description ?? 'Ready-made MyApp bundles you can open straight in Pupa.'}</p>

    <!-- How opening works (honest about the current file-open flow). -->
    <details class="mkt__how">
      <summary>How “Open in Pupa” works</summary>
      <div class="mkt__how-body">
        <p>
          A <code>.pupa</code> bundle is inert, portable data — no code runs on
          import. Tapping <strong>Open in Pupa</strong> downloads the bundle;
          your device then offers to open it in Pupa, which shows a confirm
          preview so you can <strong>review the app’s agent prompts before
          installing</strong>.
        </p>
        <ul class="mkt__how-steps">
          <li><strong>iOS:</strong> tap → “Open in Pupa” from the download.</li>
          <li><strong>macOS:</strong> the file downloads — open it to launch Pupa.</li>
        </ul>
        <p class="mkt__how-note">
          Want to publish your own app? See the{' '}
          <a href={MARKETPLACE_REPO}>marketplace repo</a>.
        </p>
      </div>
    </details>

    {index === null ? (
      <div class="mkt__error" role="alert">
        <h2 class="mkt__error-title">Catalog unavailable</h2>
        <p>
          The marketplace catalog couldn’t be reached right now. Try again
          later, or view the source on the{' '}
          <a href={MARKETPLACE_REPO}>marketplace repo</a>.
        </p>
      </div>
    ) : (
    <ul class="mkt__grid" role="list">
      {index.entries.map((e) => (
        <li class="app-card">
          <div class="app-card__head">
            <span class="app-card__icon" aria-hidden="true">{monogram(e.name)}</span>
            <div class="app-card__id">
              <h2 class="app-card__name">{e.name}</h2>
              <p class="app-card__by">by {e.author}</p>
            </div>
          </div>

          <p class="app-card__summary">{e.summary}</p>

          {e.tags.length > 0 && (
            <ul class="app-card__tags" aria-label="Tags">
              {e.tags.map((t) => <li class="app-card__tag">{t}</li>)}
            </ul>
          )}

          <dl class="app-card__meta">
            <div><dt>Size</dt><dd>{kb(e.sizeBytes)}</dd></div>
            <div><dt>Exported by</dt><dd>Pupa {e.appVersion}</dd></div>
            {e.includedRecords && <div><dt>Includes</dt><dd>sample data</dd></div>}
            {e.includedMemories && <div><dt>Includes</dt><dd>memories</dd></div>}
          </dl>

          <div class="app-card__actions">
            <a class="btn btn-primary" href={bundleURL(e)} download={`${e.id}.pupa`}>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Open in Pupa
            </a>
            {e.homepage && (
              <a class="btn" href={e.homepage}>Details</a>
            )}
          </div>
        </li>
      ))}
    </ul>
    )}

    <p class="mkt__foot">
      Catalog pinned to <a href={`${MARKETPLACE_REPO}/releases/tag/${MARKETPLACE_TAG}`}>{MARKETPLACE_TAG}</a>.
      Want your app here? <a href={`${MARKETPLACE_REPO}#publish-your-app`}>Publish it →</a>
    </p>
  </section>
</BaseLayout>
