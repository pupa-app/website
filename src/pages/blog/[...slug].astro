---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { href } from '../../lib/href';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
// Table of contents from the post's section headings (Astro auto-assigns the
// matching `id` slugs to the rendered headings, so the anchors resolve).
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="section container">
    <a class="back-link" href={href('/blog')}>← All posts</a>
    <div class="page-head" style="padding-block:0 1.5rem">
      <h1>{post.data.title}</h1>
      <p class="page-sub">
        {fmt(post.data.date)} · {post.data.author}
        {post.data.draft && <span class="badge-draft">Draft</span>}
      </p>
    </div>
    {toc.length > 1 && (
      <details class="toc" open>
        <summary class="toc__title">Contents</summary>
        <nav aria-label="Table of contents">
          <ul>
            {toc.map((h) => (
              <li class={h.depth === 3 ? 'toc__sub' : undefined}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      </details>
    )}
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
