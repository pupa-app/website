---
import BaseLayout from '../layouts/BaseLayout.astro';
import { href } from '../lib/href';

const GITHUB_ORG = 'https://github.com/pupa-app';
const MARKETPLACE = 'https://github.com/pupa-app/marketplace';

// Hero carousel — a mix of stills and portrait phone clips, told as a story:
// have apps → explore/shape → structure → agents → share. All media share the
// ~9:19.5 phone aspect so the frame never shifts. `flight-tracker.mp4` is
// landscape, so it stays in the Build card below rather than this frame.
const heroSlides = [
  { type: 'image', src: '/screens/myapps.png', w: 520, h: 1125,
    caption: 'Your MyApps, all in one place',
    alt: 'A list of MyApps in Pupa — Daily Briefing, Goodnight Stories, Movies, MyFIRE, OKRs and more.' },
  { type: 'video', src: '/videos/explore-myapp.mp4',
    caption: 'Explore and shape it by chatting',
    alt: 'Exploring a MyApp by chat — the agent reshapes the canvas live.' },
  { type: 'image', src: '/screens/job-search.png', w: 520, h: 1125,
    caption: 'Components, cross-linked into one app',
    alt: 'A Job Search MyApp home showing cross-linked components: skills, experience library, questions to ask, interview scheduler.' },
  { type: 'image', src: '/screens/slack-chat.png', w: 520, h: 1125,
    caption: 'Agents working alongside you',
    alt: 'A Pupa slack room where an agent persona (scout) works a task alongside you.' },
  { type: 'video', src: '/videos/export.mp4',
    caption: 'Share it as a portable .pupa bundle',
    alt: 'Exporting a MyApp as a portable .pupa bundle.' },
];

// Current app version — bump alongside pupa/Pupa/Sources/PupaApp/Version.swift.
const APP_VERSION = '0.0.175';
// Top-of-page tags: version + compatibility. `accent` gets the brand-red chip.
const tags = [
  { label: `v${APP_VERSION}`, title: 'Pupa iOS / macOS app version', accent: true },
  { label: 'Works with Claude Code', title: 'Link your own agent harness — Claude Code drives Pupa out of the box', icon: 'claude' },
];

const verbs = [
  {
    verb: 'Use',
    title: 'Use a MyApp daily',
    body: 'Live in it every day. Your MyApp runs on its own — open it and go, even offline. When you want it to change, just talk: the agent reshapes the blocks in front of you while you watch and edit the same screen.',
  },
  {
    verb: 'Build',
    title: 'Build a MyApp',
    body: 'Snap together whatever you need — trackers, calendars, checklists, slack rooms, calculators, charts — cross-linked into one coherent app, backed by a long-lived Memories filesystem that survives sessions.',
  },
  {
    verb: 'Share',
    title: 'Share a MyApp',
    body: 'Export any MyApp as an inert-JSON .pupa bundle and hand it to someone who runs it on their own host. Import and distribute through the marketplace — a plain HTTPS index anyone can host.',
  },
  {
    verb: 'Contribute',
    title: 'Contribute code',
    body: 'Add new blocks — canvas components — to the app, or new agent hookups to the backend. Components are just SwiftUI views with a typed model — no agentic knowledge needed to build agent-compatible surfaces.',
  },
];

const repos = [
  {
    name: 'pupa-app/pupa',
    url: `${GITHUB_ORG}/pupa`,
    desc: 'The native iOS / macOS application. Ships SwiftUI canvas, it\'s components, Memories filesystem and how those are surfaced to your backend harness.',
  },
  {
    name: 'pupa-app/pupa-backend',
    url: `${GITHUB_ORG}/pupa-backend`,
    desc: 'The user-owned backend. Hooks-up on your Agent harness on your laptop (like Claude-Code). Run it locally next to the app or deploy your own in the cloud. Pair-once auth; your keys stay yours.',
  },
  {
    name: 'pupa-app/marketplace',
    url: MARKETPLACE,
    desc: 'A catalog of .pupa bundles you can browse and install from the app. Just an HTTPS index.json anyone can host. App content is CC0; tooling is MIT.',
  },
];
---
<BaseLayout title="Pupa">
  <!-- Hero -->
  <section class="hero container">
    <ul class="hero-tags" aria-label="Version and compatibility">
      {tags.map((t) => (
        <li class={t.accent ? 'tag tag--accent' : 'tag'} title={t.title}>
          {t.icon === 'claude' && (
            <svg class="tag-icon" viewBox="0 0 100 100" width="12" height="12" fill="currentColor" aria-hidden="true">
              <path d="m19.6 66.5 19.7-11 .3-1-.3-.5h-1l-3.3-.2-11.2-.3L14 53l-9.5-.5-2.4-.5L0 49l.2-1.5 2-1.3 2.9.2 6.3.5 9.5.6 6.9.4L38 49.1h1.6l.2-.7-.5-.4-.4-.4L29 41l-10.6-7-5.6-4.1-3-2-1.5-2-.6-4.2 2.7-3 3.7.3.9.2 3.7 2.9 8 6.1L37 36l1.5 1.2.6-.4.1-.3-.7-1.1L33 25l-6-10.4-2.7-4.3-.7-2.6c-.3-1-.4-2-.4-3l3-4.2L28 0l4.2.6L33.8 2l2.6 6 4.1 9.3L47 29.9l2 3.8 1 3.4.3 1h.7v-.5l.5-7.2 1-8.7 1-11.2.3-3.2 1.6-3.8 3-2L61 2.6l2 2.9-.3 1.8-1.1 7.7L59 27.1l-1.5 8.2h.9l1-1.1 4.1-5.4 6.9-8.6 3-3.5L77 13l2.3-1.8h4.3l3.1 4.7-1.4 4.9-4.4 5.6-3.7 4.7-5.3 7.1-3.2 5.7.3.4h.7l12-2.6 6.4-1.1 7.6-1.3 3.5 1.6.4 1.6-1.4 3.4-8.2 2-9.6 2-14.3 3.3-.2.1.2.3 6.4.6 2.8.2h6.8l12.6 1 3.3 2 1.9 2.7-.3 2-5.1 2.6-6.8-1.6-16-3.8-5.4-1.3h-.8v.4l4.6 4.5 8.3 7.5L89 80.1l.5 2.4-1.3 2-1.4-.2-9.2-7-3.6-3-8-6.8h-.5v.7l1.8 2.7 9.8 14.7.5 4.5-.7 1.4-2.6 1-2.7-.6-5.8-8-6-9-4.7-8.2-.5.4-2.9 30.2-1.3 1.5-3 1.2-2.5-2-1.4-3 1.4-6.2 1.6-8 1.3-6.4 1.2-7.9.7-2.6v-.2H49L43 72l-9 12.3-7.2 7.6-1.7.7-3-1.5.3-2.8L24 86l10-12.8 6-7.9 4-4.6-.1-.5h-.3L17.2 77.4l-4.7.6-2-2 .2-3 1-1 8-5.5Z"/>
            </svg>
          )}
          {t.label}
        </li>
      ))}
    </ul>
    <h1 class="hero-wordmark">
      <img src={href('/pupa-wordmark.png')} width="1071" height="605" alt="Pupa" />
    </h1>
    <p class="lead">
      Where agentic experiences are crystallised into real apps.
    </p>
    <ul class="hero-points">
      <li><strong>Build</strong> apps for anything, from simple daily helpers, to complex automations</li>
      <li><strong>Use</strong> your apps everywhere, powered by your usual agent harness</li>
      <li><strong>Share</strong> it with anyone and enjoy others apps</li>
      <li><strong>Contribute</strong> easily your ideas to the Pupa Opensource project</li>
    </ul>
    <div class="cta-row">
      <details class="appstore">
        <summary class="btn btn-primary btn-appstore">
          <svg viewBox="0 0 384 512" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
          </svg>
          Download on the App Store
        </summary>
        <p class="appstore__soon" role="status">
          <strong>Coming soon.</strong> Pupa isn’t on the App Store just yet —
          <a href={`${GITHUB_ORG}/pupa`}>apply for a TestFlight build</a> to try it early.
        </p>
      </details>
      <a class="btn btn-primary" href={`${href('/tutorials')}#quick-setup`}>
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="8" rx="2"/>
          <rect x="2" y="14" width="20" height="8" rx="2"/>
          <path d="M6 6h.01M6 18h.01"/>
        </svg>
        Set up the backend
      </a>
      <a class="btn" href={GITHUB_ORG}>
        <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 016 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0024 12.5C24 5.87 18.63.5 12 .5z"/>
        </svg>
        View on GitHub
      </a>
      <a class="btn" href={MARKETPLACE}>
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <path d="M3 6h18"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        Browse the marketplace
      </a>
    </div>
    <div class="hero-carousel" data-carousel aria-roledescription="carousel" aria-label="Pupa running on iPhone">
      <button type="button" class="carousel__arrow carousel__arrow--prev" data-carousel-prev aria-label="Previous">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <ul class="carousel__track" data-carousel-track>
        {heroSlides.map((s, i) => (
          <li class="carousel__slide" data-carousel-slide role="group" aria-roledescription="slide" aria-label={`${i + 1} of ${heroSlides.length}`}>
            <figure class="carousel__figure">
              {s.type === 'image' ? (
                <img class="carousel__media" src={href(s.src)} width={s.w} height={s.h} alt={s.alt} loading={i === 0 ? 'eager' : 'lazy'} />
              ) : (
                <video class="carousel__media" src={href(s.src)} muted loop playsinline preload="metadata" aria-label={s.alt} title={s.alt}></video>
              )}
              <figcaption>{s.caption}</figcaption>
            </figure>
          </li>
        ))}
      </ul>
      <button type="button" class="carousel__arrow carousel__arrow--next" data-carousel-next aria-label="Next">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <div class="carousel__dots" data-carousel-dots role="tablist" aria-label="Choose slide">
        {heroSlides.map((s, i) => (
          <button type="button" class="carousel__dot" data-carousel-dot role="tab" aria-label={s.caption} aria-selected={i === 0 ? 'true' : 'false'}></button>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Pupa -->
  <section class="section container">
    <div class="why">
      <p class="section-eyebrow">Why Pupa</p>
      <h2 class="why__title">Your agentic experience, made to last</h2>
      <p class="why__lead">
        So much of what you do with an agent is lost the moment the conversation
        ends — trapped in unstructured text, or scattered across the dozen
        services you stitch together. We keep pushing agents toward more
        structure, yet the results stay fragile and fragmented.
      </p>
      <details class="why__more">
        <summary class="why__more-toggle">
          <span class="why__more-label" aria-hidden="true"></span>
          <span class="why__more-chev" aria-hidden="true">▾</span>
        </summary>
        <div class="why__more-body">
          <p class="why__lead">
            Pupa changes that. Whatever your setup — a single plain ChatGPT thread or
            an elaborate custom agentic pipeline — your same agent now can, by default, use and build a
            real app alongside you. And that app <strong>stays with you</strong>:
            Pupa gives it a standard to persist, travel, and stay robust long after
            the chat is gone and the harness changes.
          </p>
          <p class="why__lead">
            It fits either way: add a Pupa app on top of the agentic setup you already
            have, or make it the main app you use — with the agent just helping out.
          </p>
          <p class="why__lead">
            And a Pupa app is just a JSON file that Pupa connects to your backend
            agent. Nothing is locked in, so it’s <strong>fully portable</strong> and
            works with any harness.
          </p>
        </div>
      </details>
    </div>
  </section>

  <!-- Four verbs -->
  <section class="section container">
    <h2>Use, build, share, contribute</h2>
    <div class="card-grid">
      {verbs.map((v) => (
        <article class={v.verb === 'Share' || v.verb === 'Use' || v.verb === 'Build' || v.verb === 'Contribute' ? 'card card--reveal' : 'card'}>
          <span class="verb">{v.verb}</span>
          <h3>{v.title}</h3>
          <p>{v.body}</p>
          {(v.verb === 'Use' || v.verb === 'Build' || v.verb === 'Share' || v.verb === 'Contribute') && (
            <span class="reveal-hint" aria-hidden="true">
              <span class="reveal-hint__label">{v.verb === 'Contribute' ? 'Tap for the repos' : 'Tap to preview'}</span>
              <span class="reveal-hint__chev">▾</span>
            </span>
          )}
          {v.verb === 'Contribute' && (
            <div class="repo-panel">
              <div class="repo-panel__inner">
                <p class="section-eyebrow">Open source</p>
                <h3 class="repo-panel__title">Everything is open, and swappable</h3>
                <p class="repo-panel__lead">
                  The client, the backend, and the marketplace are all developed
                  in the open. See <a href={`${GITHUB_ORG}/pupa/issues`}>the repos</a>
                  {' '}for each project’s terms.
                </p>
                <div class="repo-grid">
                  {repos.map((r) => (
                    <a class="repo" href={r.url}>
                      <div class="repo-name">{r.name}</div>
                      <p>{r.desc}</p>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          )}
          {v.verb === 'Use' && (
            <div class="use-demo__panel">
              <p class="reveal-panel__cap">A day with your MyApp</p>
              <p class="reveal-panel__note">All by chat: explore what’s there, add items, log entries, and query your data — the agent updates the same screen live while you watch.</p>
              <video
                class="use-demo__video"
                src={href('/videos/daily-brief.mp4')}
                muted
                loop
                controls
                playsinline
                preload="metadata"
                title="Using a MyApp daily — a morning brief walkthrough"
              />
            </div>
          )}
          {v.verb === 'Build' && (
            <div class="use-demo__panel">
              <p class="reveal-panel__cap">Snap together components to build</p>
              <p class="reveal-panel__note">Just describe it in chat: the agent adds and wires the components you ask for — trackers, calendars, charts, checklists — into one coherent app, refining in place as you talk.</p>
              <video
                class="use-demo__video"
                src={href('/videos/flight-tracker.mp4')}
                muted
                loop
                controls
                playsinline
                preload="metadata"
                title="Building a MyApp — a flight tracker walkthrough"
              />
            </div>
          )}
          {v.verb === 'Share' && (
            <div class="share-flow__panel">
              <div class="share-flow__standard">
                <p class="section-eyebrow">The portable standard</p>
                <h3>The <code>.pupa</code> bundle</h3>
                <p>
                  One portable file holding a MyApp’s blocks, memories, and agent
                  config — no runtime. On import it runs on <strong>your</strong> host. Share directly or to marketplace to be imported by others.
                </p>
              </div>
              <img
                class="share-flow__img"
                src={href('/share-flow.png')}
                width="768"
                height="720"
                alt="Publish a MyApp to the marketplace, import one from it, or share directly device-to-device."
              />
              <video
                class="share-flow__video"
                src={href('/videos/export.mp4')}
                muted
                loop
                controls
                playsinline
                preload="metadata"
                title="Exporting a MyApp as a portable .pupa bundle"
              />
            </div>
          )}
        </article>
      ))}
    </div>
  </section>

  <script>
    // Play the daily-brief demo only while its card is hovered — no wasted
    // playback while the reveal panel is collapsed. Falls back gracefully on
    // touch (the panel opens on tap; tap the video to play).
    for (const video of document.querySelectorAll<HTMLVideoElement>('.use-demo__video, .share-flow__video')) {
      const card = video.closest('.card--reveal');
      if (!card) continue;
      card.addEventListener('mouseenter', () => {
        video.play().catch(() => {});
      });
      card.addEventListener('mouseleave', () => {
        video.pause();
        video.currentTime = 0;
      });
    }

    // Touch / no-hover: tap a reveal card to expand or collapse its panel,
    // instead of showing it always-open. Taps inside the panel (video
    // controls, links) don't toggle it shut.
    if (window.matchMedia('(hover: none)').matches) {
      for (const card of document.querySelectorAll<HTMLElement>('.card--reveal')) {
        const panel = card.querySelector('.share-flow__panel, .use-demo__panel, .repo-panel');
        card.addEventListener('click', (e) => {
          if (panel && e.target instanceof Node && panel.contains(e.target)) return;
          card.classList.toggle('is-open');
        });
      }
    }
  </script>

  <script>
    // Hero carousel — manual-first (arrows / dots / swipe / mouse-drag) with a
    // gentle autoplay that pauses on any interaction and honours reduced-motion.
    const root = document.querySelector<HTMLElement>('[data-carousel]');
    if (root) {
      const track = root.querySelector<HTMLElement>('[data-carousel-track]')!;
      const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-carousel-slide]'));
      const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-carousel-dot]'));
      const videos = slides.map((s) => s.querySelector<HTMLVideoElement>('video'));
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const INTERVAL = 5000;
      let current = 0;
      let timer = 0;
      let paused = false;

      // Rect-based math so it never depends on offsetParent quirks.
      const goTo = (i: number, smooth = true) => {
        const n = slides.length;
        const idx = ((i % n) + n) % n;
        const t = track.getBoundingClientRect();
        const s = slides[idx].getBoundingClientRect();
        const delta = (s.left + s.width / 2) - (t.left + t.width / 2);
        track.scrollTo({ left: track.scrollLeft + delta, behavior: smooth && !reduceMotion ? 'smooth' : 'auto' });
      };
      const setActive = (i: number) => {
        if (i === current) return;
        current = i;
        dots.forEach((d, di) => d.setAttribute('aria-selected', di === i ? 'true' : 'false'));
        videos.forEach((v, vi) => {
          if (!v) return;
          if (vi === i) v.play().catch(() => {});
          else { v.pause(); v.currentTime = 0; }
        });
      };

      // Derive the active slide from scroll position (covers swipe + drag + snap).
      let raf = 0;
      track.addEventListener('scroll', () => {
        if (raf) return;
        raf = requestAnimationFrame(() => {
          raf = 0;
          const t = track.getBoundingClientRect();
          const center = t.left + t.width / 2;
          let nearest = 0, min = Infinity;
          slides.forEach((s, i) => {
            const r = s.getBoundingClientRect();
            const d = Math.abs((r.left + r.width / 2) - center);
            if (d < min) { min = d; nearest = i; }
          });
          setActive(nearest);
        });
      }, { passive: true });

      // Autoplay — instant wrap from last→first to avoid a long reverse sweep.
      const stop = () => { if (timer) { clearInterval(timer); timer = 0; } };
      const start = () => {
        if (reduceMotion || paused || slides.length < 2) return;
        stop();
        timer = window.setInterval(() => {
          if (current === slides.length - 1) goTo(0, false);
          else goTo(current + 1, true);
        }, INTERVAL);
      };
      const pause = () => { paused = true; stop(); };
      const resume = () => {
        paused = false;
        // Don't fight the user if they're still hovering/focused inside.
        if (root.matches(':hover') || root.contains(document.activeElement)) return;
        start();
      };

      root.addEventListener('mouseenter', pause);
      root.addEventListener('mouseleave', resume);
      root.addEventListener('focusin', pause);
      root.addEventListener('focusout', resume);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stop();
        else if (!paused) start();
      });

      // Arrows + dots.
      root.querySelector('[data-carousel-prev]')?.addEventListener('click', () => goTo(current - 1));
      root.querySelector('[data-carousel-next]')?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

      // Mouse drag-to-scroll (touch/trackpad already scroll natively).
      let down = false, startX = 0, startLeft = 0, moved = false;
      track.addEventListener('pointerdown', (e) => {
        if (e.pointerType !== 'mouse' || e.button !== 0) return;
        down = true; moved = false; startX = e.clientX; startLeft = track.scrollLeft;
        root.classList.add('is-dragging');
        pause();
      });
      window.addEventListener('pointermove', (e) => {
        if (!down) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 4) moved = true;
        track.scrollLeft = startLeft - dx;
      });
      window.addEventListener('pointerup', () => {
        if (!down) return;
        down = false;
        root.classList.remove('is-dragging');
        goTo(current, true); // snap to nearest
        resume();
      });
      // Swallow the click that ends a drag so it doesn't count as a tap.
      track.addEventListener('click', (e) => {
        if (moved) { e.preventDefault(); e.stopPropagation(); moved = false; }
      }, true);

      start();
    }
  </script>
</BaseLayout>
