---
import BaseLayout from '../layouts/BaseLayout.astro';
import EvolutionSlider from '../components/EvolutionSlider.astro';
import { href } from '../lib/href';

const MARKETPLACE = 'https://github.com/pupa-app/marketplace';

// Hero carousel — a mix of stills and portrait phone clips, told as a story:
// have apps → explore/shape → structure → agents → share. All media share the
// ~9:19.5 phone aspect so the frame never shifts.
const heroSlides = [
  { type: 'video', src: '/videos/homepage-hero.mp4',
    caption: 'Your MyApps, all in one place',
    alt: 'A collection of MyApps in Pupa — build and use personal, AI-agent-native apps for any topic.' },
  { type: 'video', src: '/videos/myapp-schedule.mp4',
    caption: 'Build an app for anything',
    alt: 'Scheduling a MyApp in Pupa to run on its own — this example creates a schedule.' },
  { type: 'video', src: '/videos/myfire-promo.mp4',
    caption: 'Use creative apps that shape around you',
    alt: 'Building a MyApp in Pupa — this example tracks financial-independence progress.' },
];

// Hero bullet points + their lucide-style icons (stroke, currentColor).
const pointIcons = {
  build: '<path d="m15 12-9.373 9.373a1 1 0 0 1-3.001-3L12 9"/><path d="m18 15 4-4"/><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172v-.344a2 2 0 0 0-.586-1.414l-1.657-1.657A6 6 0 0 0 12.516 3H9l1.243 1.243A6 6 0 0 1 12 8.485V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5"/>',
  use: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
  share: '<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="m8.6 13.5 6.8 4"/><path d="m15.4 6.5-6.8 4"/>',
  contribute: '<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
};
// Each hero bullet links to the matching walkthrough in the tutorials (the
// homepage no longer duplicates those demos in a section of its own).
const heroPoints = [
  { icon: 'build', verb: 'Build', href: `${href('/tutorials')}#build`, body: 'apps for anything, from simple daily helpers, to complex automations' },
  { icon: 'use', verb: 'Use', href: `${href('/tutorials')}#use`, body: 'your apps everywhere, powered by your agent' },
  { icon: 'share', verb: 'Share', href: `${href('/tutorials')}#share`, body: 'apps with anyone and enjoy others apps' },
  { icon: 'contribute', verb: 'Contribute', href: `${href('/tutorials')}#contribute`, body: ' your ideas to the Pupa Opensource project' },
];

// Top-of-page tags: platform + which agent harnesses Pupa works with.
const tags = [
  { label: 'iOS & macOS', title: 'Native iOS and macOS app', icon: 'apple' },
  { label: 'Claude Code compatible', title: 'Link your own agent harness — Claude Code drives Pupa out of the box', icon: 'claude' },
  { label: 'Hermes coming soon', title: 'Hermes harness support is on the way', icon: 'hermes' },
];

---
<BaseLayout title="Pupa">
  <!-- Hero -->
  <section class="hero container">
    <ul class="hero-tags" aria-label="Harness compatibility">
      {tags.map((t) => (
        <li class={t.accent ? 'tag tag--accent' : 'tag'} title={t.title}>
          {t.icon === 'apple' && (
            <svg class="tag-icon" viewBox="0 0 384 512" width="12" height="12" fill="currentColor" aria-hidden="true">
              <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
            </svg>
          )}
          {t.icon === 'claude' && (
            <svg class="tag-icon" viewBox="0 0 100 100" width="12" height="12" fill="currentColor" aria-hidden="true">
              <path d="m19.6 66.5 19.7-11 .3-1-.3-.5h-1l-3.3-.2-11.2-.3L14 53l-9.5-.5-2.4-.5L0 49l.2-1.5 2-1.3 2.9.2 6.3.5 9.5.6 6.9.4L38 49.1h1.6l.2-.7-.5-.4-.4-.4L29 41l-10.6-7-5.6-4.1-3-2-1.5-2-.6-4.2 2.7-3 3.7.3.9.2 3.7 2.9 8 6.1L37 36l1.5 1.2.6-.4.1-.3-.7-1.1L33 25l-6-10.4-2.7-4.3-.7-2.6c-.3-1-.4-2-.4-3l3-4.2L28 0l4.2.6L33.8 2l2.6 6 4.1 9.3L47 29.9l2 3.8 1 3.4.3 1h.7v-.5l.5-7.2 1-8.7 1-11.2.3-3.2 1.6-3.8 3-2L61 2.6l2 2.9-.3 1.8-1.1 7.7L59 27.1l-1.5 8.2h.9l1-1.1 4.1-5.4 6.9-8.6 3-3.5L77 13l2.3-1.8h4.3l3.1 4.7-1.4 4.9-4.4 5.6-3.7 4.7-5.3 7.1-3.2 5.7.3.4h.7l12-2.6 6.4-1.1 7.6-1.3 3.5 1.6.4 1.6-1.4 3.4-8.2 2-9.6 2-14.3 3.3-.2.1.2.3 6.4.6 2.8.2h6.8l12.6 1 3.3 2 1.9 2.7-.3 2-5.1 2.6-6.8-1.6-16-3.8-5.4-1.3h-.8v.4l4.6 4.5 8.3 7.5L89 80.1l.5 2.4-1.3 2-1.4-.2-9.2-7-3.6-3-8-6.8h-.5v.7l1.8 2.7 9.8 14.7.5 4.5-.7 1.4-2.6 1-2.7-.6-5.8-8-6-9-4.7-8.2-.5.4-2.9 30.2-1.3 1.5-3 1.2-2.5-2-1.4-3 1.4-6.2 1.6-8 1.3-6.4 1.2-7.9.7-2.6v-.2H49L43 72l-9 12.3-7.2 7.6-1.7.7-3-1.5.3-2.8L24 86l10-12.8 6-7.9 4-4.6-.1-.5h-.3L17.2 77.4l-4.7.6-2-2 .2-3 1-1 8-5.5Z"/>
            </svg>
          )}
          {t.icon === 'hermes' && (
            <svg class="tag-icon" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 15a6 6 0 0 1 12 0v2H6z"/>
              <path d="M18 9c2.4-1.1 4-.2 4-.2s-1.6 2.4-4 2.4"/>
              <path d="M6 9C3.6 7.9 2 8.8 2 8.8s1.6 2.4 4 2.4"/>
            </svg>
          )}
          {t.label}
        </li>
      ))}
    </ul>
    <h1 class="hero-wordmark">
      <img src={href('/pupa-wordmark.png')} width="1071" height="605" alt="Pupa" />
    </h1>
    <p class="lead">
      Agentic experiences crystallised into real apps.
    </p>
    <ul class="hero-points">
      {heroPoints.map((p) => (
        <li>
          <a class="hero-point" href={p.href}>
            <svg class="hero-point__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={pointIcons[p.icon]}></svg>
            <span><strong>{p.verb}</strong> {p.body}</span>
          </a>
        </li>
      ))}
    </ul>
    <div class="cta-row">
      <details class="appstore">
        <summary class="btn btn-primary btn-appstore">
          <svg viewBox="0 0 384 512" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
          </svg>
          Download on the App Store
        </summary>
        <p class="appstore__soon" role="status">
          <strong>Coming soon.</strong> Pupa isn’t on the App Store just yet — email{' '}
          <a href="mailto:pupa-app-help@proton.me?subject=TestFlight%20request">pupa-app-help@proton.me</a> to request a TestFlight invite and try it early.
        </p>
      </details>
      <a class="btn btn-primary" href={`${href('/tutorials')}#quick-setup`}>
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3.5 13.8 8.6a3 3 0 0 0 1.8 1.8l5.1 1.8-5.1 1.8a3 3 0 0 0-1.8 1.8L12 20.9l-1.8-5.1a3 3 0 0 0-1.8-1.8L3.3 12.2l5.1-1.8a3 3 0 0 0 1.8-1.8z"/>
          <path d="M19 3v3M20.5 4.5h-3"/>
          <path d="M5 17v2.5M6.25 18.25h-2.5"/>
        </svg>
        Connect your agent
      </a>
      <a class="btn btn-primary" href={MARKETPLACE}>
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <path d="M3 6h18"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        Browse the marketplace
      </a>
    </div>
    <div class="hero-carousel" data-carousel aria-roledescription="carousel" aria-label="Pupa running on iPhone">
      <button type="button" class="carousel__arrow carousel__arrow--prev" data-carousel-prev aria-label="Previous">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <ul class="carousel__track" data-carousel-track>
        {heroSlides.map((s, i) => (
          <li class="carousel__slide" data-carousel-slide role="group" aria-roledescription="slide" aria-label={`${i + 1} of ${heroSlides.length}`}>
            <figure class="carousel__figure">
              {s.type === 'image' ? (
                <img class="carousel__media" src={href(s.src)} width={s.w} height={s.h} alt={s.alt} loading={i === 0 ? 'eager' : 'lazy'} />
              ) : (
                <video class="carousel__media" src={href(s.src)} muted loop playsinline preload="metadata" aria-label={s.alt} title={s.alt}></video>
              )}
              <figcaption>{s.caption}</figcaption>
            </figure>
          </li>
        ))}
      </ul>
      <button type="button" class="carousel__arrow carousel__arrow--next" data-carousel-next aria-label="Next">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <button type="button" class="carousel__sound" data-carousel-sound aria-label="Unmute" aria-pressed="false" hidden>
        <svg class="ico ico--muted" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5 6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
        <svg class="ico ico--on" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/><path d="M19 5a9 9 0 0 1 0 14"/></svg>
      </button>
      <div class="carousel__dots" data-carousel-dots role="tablist" aria-label="Choose slide">
        {heroSlides.map((s, i) => (
          <button type="button" class="carousel__dot" data-carousel-dot role="tab" aria-label={s.caption} aria-selected={i === 0 ? 'true' : 'false'}></button>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Pupa -->
  <section class="section container">
    <div class="why">
      <p class="section-eyebrow">Why Pupa</p>
      <h2 class="why__title">Your agentic experience, made to last</h2>
      <p class="why__lead">
        So much of what you do with an agent is lost the moment the conversation
        ends — trapped in unstructured text, or scattered across the dozen
        services you stitch together. We keep pushing agents toward more
        structure, yet the results stay fragile and fragmented.
      </p>
      <details class="why__more">
        <summary class="why__more-toggle">
          <span class="why__more-label" aria-hidden="true"></span>
          <span class="why__more-chev" aria-hidden="true">▾</span>
        </summary>
        <div class="why__more-body">
          <p class="why__lead">
            Pupa changes that. Whatever your setup — a single plain ChatGPT thread or
            an elaborate custom agentic pipeline — your same agent now can, by default, use and build a
            real app alongside you. And that app <strong>stays with you</strong>:
            Pupa gives it a standard to persist, travel, and stay robust long after
            the chat is gone and the harness changes.
          </p>
          <p class="why__lead">
            It fits either way: add a Pupa app on top of the agentic setup you already
            have, or make it the main app you use — with the agent just helping out.
          </p>
          <p class="why__lead">
            And a Pupa app is just a JSON file that Pupa connects to your backend
            agent. Nothing is locked in, so it’s <strong>fully portable</strong> and
            works with any harness.
          </p>
          <p class="why__evo-lead">The app surface has been evolving — step through it:</p>
          <EvolutionSlider />
        </div>
      </details>
    </div>
  </section>

  <script>
    // Hero carousel — manual-first (arrows / dots / swipe / mouse-drag) with a
    // gentle autoplay that pauses on any interaction and honours reduced-motion.
    const root = document.querySelector<HTMLElement>('[data-carousel]');
    if (root) {
      const track = root.querySelector<HTMLElement>('[data-carousel-track]')!;
      const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-carousel-slide]'));
      const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-carousel-dot]'));
      const videos = slides.map((s) => s.querySelector<HTMLVideoElement>('video'));
      const soundBtn = root.querySelector<HTMLButtonElement>('[data-carousel-sound]');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const INTERVAL = 5000;
      let current = 0;
      let timer = 0;
      let paused = false;
      let soundOn = false; // audio only after a user gesture (autoplay policy)

      // Show the unmute button only on slides that have a video; reflect state.
      const syncSound = () => {
        if (!soundBtn) return;
        soundBtn.hidden = !videos[current];
        soundBtn.setAttribute('aria-pressed', soundOn ? 'true' : 'false');
        soundBtn.setAttribute('aria-label', soundOn ? 'Mute' : 'Unmute');
      };

      // Rect-based math so it never depends on offsetParent quirks.
      const goTo = (i: number, smooth = true) => {
        const n = slides.length;
        const idx = ((i % n) + n) % n;
        const t = track.getBoundingClientRect();
        const s = slides[idx].getBoundingClientRect();
        const delta = (s.left + s.width / 2) - (t.left + t.width / 2);
        track.scrollTo({ left: track.scrollLeft + delta, behavior: smooth && !reduceMotion ? 'smooth' : 'auto' });
      };
      const setActive = (i: number) => {
        if (i === current) return;
        current = i;
        dots.forEach((d, di) => d.setAttribute('aria-selected', di === i ? 'true' : 'false'));
        videos.forEach((v, vi) => {
          if (!v) return;
          if (vi === i) { v.muted = !soundOn; v.play().catch(() => {}); }
          else { v.pause(); v.currentTime = 0; v.muted = true; }
        });
        syncSound();
      };

      // Derive the active slide from scroll position (covers swipe + drag + snap).
      let raf = 0;
      track.addEventListener('scroll', () => {
        if (raf) return;
        raf = requestAnimationFrame(() => {
          raf = 0;
          const t = track.getBoundingClientRect();
          const center = t.left + t.width / 2;
          let nearest = 0, min = Infinity;
          slides.forEach((s, i) => {
            const r = s.getBoundingClientRect();
            const d = Math.abs((r.left + r.width / 2) - center);
            if (d < min) { min = d; nearest = i; }
          });
          setActive(nearest);
        });
      }, { passive: true });

      // Autoplay — instant wrap from last→first to avoid a long reverse sweep.
      const stop = () => { if (timer) { clearInterval(timer); timer = 0; } };
      const start = () => {
        if (reduceMotion || paused || soundOn || slides.length < 2) return;
        stop();
        timer = window.setInterval(() => {
          if (current === slides.length - 1) goTo(0, false);
          else goTo(current + 1, true);
        }, INTERVAL);
      };
      const pause = () => { paused = true; stop(); };
      const resume = () => {
        paused = false;
        // Don't fight the user if they're still hovering/focused inside.
        if (root.matches(':hover') || root.contains(document.activeElement)) return;
        start();
      };

      root.addEventListener('mouseenter', pause);
      root.addEventListener('mouseleave', resume);
      root.addEventListener('focusin', pause);
      root.addEventListener('focusout', resume);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stop();
        else if (!paused) start();
      });

      // Arrows + dots.
      root.querySelector('[data-carousel-prev]')?.addEventListener('click', () => goTo(current - 1));
      root.querySelector('[data-carousel-next]')?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

      // Sound: gesture-gated. On → unmute active clip + stop autoplay; off → mute + resume.
      soundBtn?.addEventListener('click', () => {
        soundOn = !soundOn;
        const v = videos[current];
        if (soundOn) {
          stop();
          if (v) { v.muted = false; v.play().catch(() => {}); }
        } else {
          if (v) v.muted = true;
          start();
        }
        syncSound();
      });

      // Mouse drag-to-scroll (touch/trackpad already scroll natively).
      let down = false, startX = 0, startLeft = 0, moved = false;
      track.addEventListener('pointerdown', (e) => {
        if (e.pointerType !== 'mouse' || e.button !== 0) return;
        down = true; moved = false; startX = e.clientX; startLeft = track.scrollLeft;
        root.classList.add('is-dragging');
        pause();
      });
      window.addEventListener('pointermove', (e) => {
        if (!down) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 4) moved = true;
        track.scrollLeft = startLeft - dx;
      });
      window.addEventListener('pointerup', () => {
        if (!down) return;
        down = false;
        root.classList.remove('is-dragging');
        goTo(current, true); // snap to nearest
        resume();
      });
      // Swallow the click that ends a drag so it doesn't count as a tap.
      track.addEventListener('click', (e) => {
        if (moved) { e.preventDefault(); e.stopPropagation(); moved = false; }
      }, true);

      // Kick off the first slide's video (setActive only fires on change).
      const first = videos[current];
      if (first) { first.muted = !soundOn; first.play().catch(() => {}); }
      syncSound();
      start();
    }
  </script>
</BaseLayout>
