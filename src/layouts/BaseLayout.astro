---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { href } from '../lib/href';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Pupa — an open-source native iOS/macOS agent app. Talk, and your agent snaps together apps from Lego-like blocks — trackers, calendars, checklists, and more — backed by a long-lived Memories filesystem, packaged as a portable .pupa bundle.',
} = Astro.props;

const fullTitle = title === 'Pupa' ? 'Pupa' : `${title} · Pupa`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <link rel="icon" type="image/png" href={href('/favicon.png?v=2')} />
    <link rel="apple-touch-icon" href={href('/apple-touch-icon.png?v=2')} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
